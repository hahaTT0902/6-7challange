// Prisma schema for 67 Challenge
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Score {
  id        Int      @id @default(autoincrement())
  nickname  String   @db.VarChar(20)
  score     Int
  userAgent String?  @db.VarChar(255)
  ipHash    String?  @db.VarChar(128)
  createdAt DateTime @default(now())

  // Optional link to a registered account. When set, this row is the user's
  // single "verified" leaderboard entry (kept as their personal best).
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id])

  @@index([score])
  @@index([createdAt])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(20)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())

  score        Score?
  duelsCreated Duel[]   @relation("DuelCreator")
  duelsJoined  Duel[]   @relation("DuelOpponent")
}

model Duel {
  id            Int       @id @default(autoincrement())
  code          String    @unique @db.VarChar(8)
  status        String    @default("pending") @db.VarChar(16) // pending | playing | done

  creatorId     Int
  creator       User      @relation("DuelCreator", fields: [creatorId], references: [id])
  creatorScore  Int?
  creatorPlayed Boolean   @default(false)

  opponentId    Int?
  opponent      User?     @relation("DuelOpponent", fields: [opponentId], references: [id])
  opponentScore Int?
  opponentPlayed Boolean  @default(false)

  createdAt     DateTime  @default(now())
  finishedAt    DateTime?

  @@index([code])
  @@index([status])
}

